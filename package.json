{
  "name": "caedro_app",
  "private": true,
  "version": "1.3.1",
  "author": "Sebastian Lopez <sebaslg96@gmail.com>",
  "description": "Caedro ERP System",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:react": "vite build",
    "obfuscate": "javascript-obfuscator ./electron --output ./electron-dist --target node --compact true --control-flow-flattening true --string-array true --string-array-encoding rc4 --dead-code-injection true",
    "build:all": "npm run build:react && npm run obfuscate",
    "pack": "npm run build:all && electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "publish-win": "npm run build:all && electron-builder --win --publish always",
    "publish-linux": "npm run build:all && electron-builder --linux --publish always"
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "bootstrap": "^5.3.8",
    "csv-parser": "^3.2.1",
    "datatables.net-bs5": "^2.3.4",
    "datatables.net-dt": "^2.3.4",
    "datatables.net-react": "^1.0.1",
    "electron-updater": "^6.6.2",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.9.6",
    "sweetalert2": "^11.26.3",
    "uuid": "^13.0.0"
  },
  "build": {
    "appId": "com.codepez.caedro",
    "productName": "Caedro ERP",
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json",
      {
        "from": "electron-dist",
        "to": "electron"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sebaslopezg",
        "repo": "caedro_app_production",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/favicon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/favicon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/favicon.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "bytenode": "^1.6.0",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.6.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^2.0.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "javascript-obfuscator": "^5.4.3",
    "vite": "^7.1.7",
    "wait-on": "^9.0.3"
  }
}